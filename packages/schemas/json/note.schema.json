{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/invariance-ai/dna/schemas/note.schema.json",
  "title": "dna note",
  "$ref": "#/definitions/dna note",
  "definitions": {
    "dna note": {
      "type": "object",
      "properties": {
        "symbol": {
          "type": "string"
        },
        "lesson": {
          "type": "string"
        },
        "evidence": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ],
          "default": "medium"
        },
        "promoted": {
          "type": "boolean",
          "default": false
        },
        "recorded_at": {
          "type": "string"
        },
        "source": {
          "type": "string",
          "enum": [
            "agent",
            "human",
            "doc",
            "git",
            "promoted",
            "todo"
          ],
          "default": "agent"
        },
        "id": {
          "type": "string"
        },
        "scope": {
          "type": "string",
          "enum": [
            "symbol",
            "file",
            "feature",
            "global"
          ],
          "default": "symbol"
        },
        "applies_to": {
          "type": "string"
        },
        "classifier": {
          "type": "object",
          "properties": {
            "signals": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "used_llm": {
              "type": "boolean",
              "default": false
            },
            "model": {
              "type": "string"
            }
          },
          "required": [
            "confidence"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "symbol",
        "lesson",
        "recorded_at"
      ],
      "additionalProperties": false
    }
  }
}
