{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/invariance-ai/dna/schemas/note.schema.json",
  "title": "dna note",
  "$ref": "#/definitions/dna note",
  "definitions": {
    "dna note": {
      "type": "object",
      "properties": {
        "symbol": {
          "type": "string"
        },
        "lesson": {
          "type": "string"
        },
        "evidence": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ],
          "default": "medium"
        },
        "promoted": {
          "type": "boolean",
          "default": false
        },
        "recorded_at": {
          "type": "string"
        },
        "source": {
          "type": "string",
          "enum": [
            "agent",
            "human",
            "doc",
            "git",
            "promoted",
            "todo",
            "pr",
            "incident",
            "transcript",
            "seed",
            "pulse"
          ],
          "default": "agent"
        },
        "id": {
          "type": "string"
        },
        "scope": {
          "type": "string",
          "enum": [
            "symbol",
            "file",
            "feature",
            "area",
            "global"
          ],
          "default": "symbol"
        },
        "applies_to": {
          "type": "string"
        },
        "classifier": {
          "type": "object",
          "properties": {
            "signals": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "used_llm": {
              "type": "boolean",
              "default": false
            },
            "model": {
              "type": "string"
            }
          },
          "required": [
            "confidence"
          ],
          "additionalProperties": false
        },
        "evidence_link": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "verified_by": {
          "type": "string"
        },
        "verified_at": {
          "type": "string"
        },
        "author": {
          "type": "string"
        },
        "anchor_id": {
          "type": "string"
        },
        "source_commit": {
          "type": "string"
        },
        "expires_at": {
          "type": "string"
        }
      },
      "required": [
        "symbol",
        "lesson",
        "recorded_at"
      ],
      "additionalProperties": false
    }
  }
}
