{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/invariance-ai/dna/schemas/config.schema.json",
  "title": "dna config",
  "$ref": "#/definitions/dna config",
  "definitions": {
    "dna config": {
      "type": "object",
      "properties": {
        "languages": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "typescript",
              "python",
              "javascript"
            ]
          },
          "default": [
            "typescript"
          ]
        },
        "exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "depth": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "default": 3
        },
        "strands": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "structural",
              "tests",
              "provenance",
              "invariants"
            ]
          },
          "default": [
            "structural",
            "tests",
            "provenance",
            "invariants"
          ]
        }
      },
      "additionalProperties": false,
      "description": "dna repo configuration written to .dna/config.yml by `dna init`."
    }
  }
}
