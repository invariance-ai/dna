{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/invariance-ai/dna/schemas/decision.schema.json",
  "title": "dna decision",
  "$ref": "#/definitions/dna decision",
  "definitions": {
    "dna decision": {
      "type": "object",
      "properties": {
        "symbol": {
          "type": "string"
        },
        "decision": {
          "type": "string"
        },
        "rejected_alternative": {
          "type": "string"
        },
        "rationale": {
          "type": "string"
        },
        "made_by": {
          "type": "string"
        },
        "session": {
          "type": "string"
        },
        "recorded_at": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "source": {
          "type": "string",
          "enum": [
            "human",
            "agent",
            "transcript",
            "pr",
            "seed",
            "promoted"
          ],
          "default": "human"
        },
        "evidence_link": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "verified_by": {
          "type": "string"
        },
        "verified_at": {
          "type": "string"
        }
      },
      "required": [
        "symbol",
        "decision",
        "recorded_at"
      ],
      "additionalProperties": false
    }
  }
}
