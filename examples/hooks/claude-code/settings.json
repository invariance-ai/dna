{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "dna gate --changed --json 2>&1 | head -200"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "dna review-diff --json 2>&1 | head -200"
          }
        ]
      }
    ]
  }
}
