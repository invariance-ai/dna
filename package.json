{
  "name": "dna-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Codebase context for coding agents",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/invariance-ai/dna.git"
  },
  "homepage": "https://github.com/invariance-ai/dna",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "dev": "pnpm -r --parallel dev",
    "bench:perf": "tsx bench/perf/run.ts",
    "bench:compare": "tsx bench/perf/compare-all.ts",
    "bench:compare:self": "tsx bench/perf/compare-all.ts --corpus self --skip-cmm --skip-accuracy",
    "bench:compare:flask": "tsx bench/perf/compare-all.ts --corpus flask",
    "bench:compare:django": "tsx bench/perf/compare-all.ts --corpus django -n 8",
    "release": "tsx scripts/release.ts",
    "release:check": "tsx scripts/release.ts --check"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20"
  }
}
